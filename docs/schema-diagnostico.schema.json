{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ResolveCoreDiagnostic",
  "description": "Esquema unificado JSON de diagnóstico para ResolveCore",
  "type": "object",
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "plataforma": { "type": "string", "enum": ["windows", "linux", "android", "macos"] },
        "hostname": { "type": "string" },
        "generado_en": { "type": "string", "format": "date-time" },
        "admin": { "type": "boolean" },
        "stub": { "type": "boolean" }
      },
      "required": ["version", "plataforma", "hostname", "generado_en"]
    },
    "hardware": {
      "type": "object",
      "properties": {
        "cpu": {
          "type": "object",
          "properties": {
            "cantidad": { "type": "integer" },
            "nucleos_total": { "type": "integer" },
            "hilos_total": { "type": "integer" },
            "processors": { "type": "array" },
            "cpu_nombre": { "type": "string" },
            "cpu_cores": { "type": "integer" }
          }
        },
        "memoria": {
          "type": "object",
          "properties": {
            "total_gb": { "type": "number" },
            "disponible_gb": { "type": "number" },
            "usada_gb": { "type": "number" },
            "modulos": { "type": "array" }
          }
        },
        "discos": {
          "type": ["object", "array"]
        },
        "gpu": {
          "type": ["array", "null", "string", "object"]
        },
        "placa_base": {
          "type": "object"
        },
        "bateria": {
          "type": ["object", "null"]
        },
        "smart": {
          "type": ["array", "null"]
        },
        "ram_gb": { "type": "number" },
        "disk_type": { "type": "string" },
        "disk_gb": { "type": "number" },
        "smart_status": { "type": ["string", "null"] }
      }
    },
    "sistema": { "type": "object" },
    "sistema_operativo": { "type": "object" },
    "red": { "type": "object" },
    "seguridad": { "type": "object" },
    "servicios": { "type": "object" },
    "software": { "type": "object" },
    "rendimiento": { "type": "object" },
    "usuarios": { "type": "array" },
    "drivers": { "type": "object" },
    "aplicaciones": { "type": "object" },
    "dispositivo": { "type": "object" }
  },
  "required": ["_meta", "hardware"]
}
