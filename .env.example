# ── Supabase (obligatorio) ────────────────────────────────────────────────────
# Obtén estos valores en: https://supabase.com/dashboard → proyecto → Settings → API
VITE_SUPABASE_URL=https://<tu-proyecto>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# ── NVD API Key (opcional, aumenta el rate limit de 5 a 50 req/30s) ──────────
# Regístrate gratis en: https://nvd.nist.gov/developers/request-an-api-key
# IMPORTANTE: Esta variable va en Vercel sin prefijo VITE_ (es server-side)
NVD_API_KEY=
